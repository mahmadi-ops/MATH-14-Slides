<?xml version="1.0" encoding="utf-8"?>
<project ptx-version="2">
  <targets>
    <target name="slides"
            format="revealjs"
            source="path-independence.ptx"
            publication="publication.ptx"
            output-dir="slides"/>
    <target name="line-integrals"
            format="revealjs"
            source="line-integrals.ptx"
            publication="publication.ptx"
            output-dir="line-integrals"/>
    <target name="main"
            format="revealjs"
            source="main.ptx"
            publication="publication.ptx"
            output-dir="main"/>
  </targets>
</project>
